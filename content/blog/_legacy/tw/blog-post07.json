>\n                \n                \n                \n                \n                \n                \n                \n                <img data-stretch=\"false\" data-src=\"/images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png\" data-image=\"/images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png\" data-image-dimensions=\"2600x3899\" data-image-focal-point=\"0.5,0.5\" alt=\"\" data-load=\"false\" elementtiming=\"system-image-block\" data-sqsp-image-classic-block-image src=\"/images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png\" width=\"2600\" height=\"3899\" alt=\"\" sizes=\"(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw\" style=\"display:block;object-fit: cover; width: 100%; height: 100%; object-position: 50% 50%\" onload=\"this.classList.add(&quot;loaded&quot;)\" srcset=\"/images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 100w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 300w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 500w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 750w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 1000w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 1500w, /images/dae7248b-d10f-4766-9f43-555c390580fe/_+_+1-01.png 2500w\" loading=\"lazy\" decoding=\"async\" data-loader=\"sqs\">\n\n            </div>\n          </div>\n        \n          \n        \n\n        \n      \n        </figure>\n      \n\n    </div>\n  \n\n\n  \n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"e09628bbde5d7f116bc0\" id=\"block-e09628bbde5d7f116bc0\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><span class=\"sqsrte-text-color--custom\" style=\"color: #6A6360\">創喜設計總監-龐甄嬉／Photo Credit：甄嬉</span></p><p class=\"\" style=\"white-space:pre-wrap;\">在快節奏的生活裡，有多少人真的能「自在」地過每一天？又有多少人能在面對人生起起落落時，依然淡定從容？「自在」和「淡定」就是創喜設計總監-龐甄嬉身上散發出來的獨特氣質，「生活就是要開心，有壓力，事情就做不好。」面對生活中的挑戰，甄嬉用「玩」心，為每一天注入期待，用內在的平靜與信仰，對抗外在的不確定與喧囂。  <br><br>「我小時候是跑田徑的，還是最後一棒。」運動員的經驗對她來說，不只是一段回憶，而是一種內建的節奏感與底氣來源。「訓練跑步的過程，其實是跟自己的對話，每個當下只要多堅持一下，每天比昨天進步一點點，也許就可以是前幾名。」這份從小建立起的專注與爆發力，如今成了她創作與生活上的穩定核心。<br> </p></div>\n\n\n  \n<style id=\"container-styles\">#block-e09628bbde5d7f116bc0 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-e09628bbde5d7f116bc0 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initial;\n}\n\n  #block-e09628bbde5d7f116bc0 {\n      mix-blend-mode: var(--tweak-text-block-blend\n  );\n      border-radius: var(--tweak-text-block-radius);\n  }\n\n  \n  \n#block-e09628bbde5d7f116bc0 {\n      --tweak-text-block-radius: 0px 0px 0px 0px;\n    }\n\n\n  \n  \n\n  #block-e09628bbde5d7f116bc0 {\n    }\n\n</style>\n\n<style id=\"override-container-styles\">\n    @media screen and (max-width: 767px) {\n          \n            \n\n#block-e09628bbde5d7f116bc0 {\n            \n            }\n        }\n    \n  \n    @media screen and (max-width: 767px) {\n          #block-e09628bbde5d7f116bc0 .sqs-html-content {\n            \n            }\n        }\n    \n  @media screen and (max-width: 767px) {\n          \n          \n\n          \n          \n          \n        }</style>\n\n<style class=\"transform-overrides-vars\">\n    \n  </style>\n\n\n\n</div>\n</div></div><div class=\"sqs-block image-block sqs-block-image\" data-block-type=\"5\" data-sqsp-block=\"image-classic\" id=\"block-yui_3_17_2_1_1754556963442_11770\"><div class=\"sqs-block-content\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n  \n\n    \n  \n    <div\n        class=\"\n          image-block-outer-wrapper\n          layout-caption-hidden\n          design-layout-inline\n          combination-animation-site-default\n          individual-animation-site-default\n          individual-text-animation-site-default\n        \"\n        data-test=\"image-block-inline-outer-wrapper\"\n        data-sqsp-image-classic-block-layout=\"inline\"\n    >\n\n      \n\n      \n        <figure\n            class=\"\n              sqs-block-image-figure\n              intrinsic\n            \"\n            style=\"max-width:1562px;\"\n        >\n          \n        \n        \n\n        \n          \n            \n          <div\n              \n              \n              class=\"image-block-wrapper\"\n              data-animation-role=\"image\"\n              \n  \n\n          >\n            <div data-sqsp-image-classic-block-image-container class=\"sqs-image-shape-container-element\n              \n          \n        \n              has-aspect-ratio\n            \" style=\"\n                position: relative;\n                \n                  padding-bottom:80.02560424804688%;\n                \n                overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);\n              \"\n              >\n                \n                \n                \n                \n                \n                \n                \n                <img data-stretch=\"false\" data-src=\"/images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png\" data-image=\"/images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png\" data-image-dimensions=\"1562x1250\" data-image-focal-point=\"0.5,0.5\" alt=\"\" data-load=\"false\" elementtiming=\"system-image-block\" data-sqsp-image-classic-block-image src=\"/images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png\" width=\"1562\" height=\"1250\" alt=\"\" sizes=\"(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw\" style=\"display:block;object-fit: cover; width: 100%; height: 100%; object-position: 50% 50%\" onload=\"this.classList.add(&quot;loaded&quot;)\" srcset=\"/images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 100w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 300w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 500w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 750w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 1000w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 1500w, /images/de96fac8-9f6c-45b9-af93-b9d56c12d625/22-01.png 2500w\" loading=\"lazy\" decoding=\"async\" data-loader=\"sqs\">\n\n            </div>\n          </div>\n        \n          \n        \n\n        \n      \n        </figure>\n      \n\n    </div>\n  \n\n\n  \n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"yui_3_17_2_1_1754556963442_13149\" id=\"block-yui_3_17_2_1_1754556963442_13149\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><p style=\"text-align:center;white-space:pre-wrap;\" class=\"sqsrte-small\"><span class=\"sqsrte-text-color--custom\" style=\"color: #6A6360\">創喜設計總監-龐甄嬉／Photo Credit：甄嬉</span></p><h4 style=\"white-space:pre-wrap;\"><strong>在自媒體爆炸、AI 內容充斥的時代，當多數人將目光放在流量與曝光上，甄嬉選擇回到創作的本質，做自己投入的內容。</strong></h4><p class=\"\" style=\"white-space:pre-wrap;\">她以「別人做過的，我就不想重複」的堅持，走出個人風格，不打廣告、不照劇本，用最真實的方式，累積出屬於自己的觀眾與影響力。她相信，熱忱與投入是無法偽裝的，不追求一次到位的完美，而是在每一次創作中穩定前行，讓目標在持續累積中不斷靠近。  <br><br>人如其名——「甄嬉」出現的地方，彷彿連空氣都飄著快樂的花香，蝴蝶也忍不住翩翩飛舞！身為一個把「追求快樂」當成人生座右銘的樂天派，甄嬉的能量，正好與山恩一直以來相信的精神「Have FUN」完美契合。這樣的她，是 Saiens Salon 不可或缺的一份子！4 月的 Saiens Salon 甄嬉邀請了 10 位朋友，來到山恩台北展間，體驗一場最有「甄嬉」風格的夜晚，也是山恩首度由設計師親自發起的晚餐聚會。  </p></div>\n\n\n  \n<style id=\"container-styles\">#block-yui_3_17_2_1_1754556963442_13149 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-yui_3_17_2_1_1754556963442_13149 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initial;\n}\n\n  #block-yui_3_17_2_1_1754556963442_13149 {\n      mix-blend-mode: var(--tweak-text-block-blend\n  );\n      border-radius: var(--tweak-text-block-radius);\n  }\n\n  \n  \n#block-yui_3_17_2_1_1754556963442_13149 {\n      --tweak-text-block-radius: 0px 0px 0px 0px;\n    }\n\n\n  \n  \n\n  #block-yui_3_17_2_1_1754556963442_13149 {\n    }\n\n</style>\n\n<style id=\"override-container-styles\">\n    @media screen and (max-width: 767px) {\n          \n            \n\n#block-yui_3_17_2_1_1754556963442_13149 {\n            \n            }\n        }\n    \n  \n    @media screen and (max-width: 767px) {\n          #block-yui_3_17_2_1_1754556963442_13149 .sqs-html-content {\n            \n            }\n        }\n    \n  @media screen and (max-width: 767px) {\n          \n          \n\n          \n          \n          \n        }</style>\n\n<style class=\"transform-overrides-vars\">\