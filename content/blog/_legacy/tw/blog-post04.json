    \n                \n                \n                \n                \n                <img data-stretch=\"false\" data-src=\"/images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg\" data-image=\"/images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg\" data-image-dimensions=\"6855x4514\" data-image-focal-point=\"0.5,0.5\" alt=\"\" data-load=\"false\" elementtiming=\"system-image-block\" data-sqsp-image-classic-block-image src=\"/images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg\" width=\"6855\" height=\"4514\" alt=\"\" sizes=\"(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw\" style=\"display:block;object-fit: cover; width: 100%; height: 100%; object-position: 50% 50%\" onload=\"this.classList.add(&quot;loaded&quot;)\" srcset=\"/images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 100w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 300w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 500w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 750w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 1000w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 1500w, /images/1752483346722-VBT13B1NBQPRE7T51E2Z/DSC02792-2.jpg 2500w\" loading=\"lazy\" decoding=\"async\" data-loader=\"sqs\">\n\n            </div>\n          </div>\n        \n          \n        \n\n        \n      \n        </figure>\n      \n\n    </div>\n  \n\n\n  \n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definitio