overflow: hidden;-webkit-mask-image: -webkit-radial-gradient(white, black);\n              \"\n              >\n                \n                \n                \n                \n                \n                \n                \n                <img data-stretch=\"false\" data-src=\"/images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg\" data-image=\"/images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg\" data-image-dimensions=\"4206x3365\" data-image-focal-point=\"0.5,0.5\" alt=\"\" data-load=\"false\" elementtiming=\"system-image-block\" data-sqsp-image-classic-block-image src=\"/images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg\" width=\"4206\" height=\"3365\" alt=\"\" sizes=\"(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw\" style=\"display:block;object-fit: cover; width: 100%; height: 100%; object-position: 50% 50%\" onload=\"this.classList.add(&quot;loaded&quot;)\" srcset=\"/images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 100w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 300w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 500w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 750w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 1000w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 1500w, /images/1753077407730-CPKNHG9UNIXCM6P6PME6/_.jpg 2500w\" loading=\"lazy\" decoding=\"async\" data-loader=\"sqs\">\n\n            </div>\n          </div>\n        \n          \n        \n\n        \n      \n        </figure>\n      \n\n    </div>\n  \n\n\n  \n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"yui_3_17_2_1_1756882003224_4656\" id=\"block-yui_3_17_2_1_1756882003224_4656\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"white-space:pre-wrap;\">台鉄観光列車「鳴日號」から「鳴日廚房」へ</h4><p class=\"\" style=\"white-space:pre-wrap;\">2020年に運行を開始した台鉄のデザイン観光列車「鳴日號」。<br> そのアップグレード版となる「鳴日廚房」が、2年ぶりに今春ついに登場しました。</p><p class=\"\" style=\"white-space:pre-wrap;\">国際水準の観光列車を目指した「鳴日廚房」は、外観から車内デザイン、インテリアに至るまで台湾のデザイン会社 <strong>J.C.Architecture 柏成設計</strong> が手がけています。さらに、食の面では <strong>晶華國際酒店 Regent Taipei</strong> が監修し、地元の旬の食材を使った特別なコース料理を提供。まさに「走る五星級レストラン」と呼ぶにふさわしい体験です。</p><p class=\"\" style=\"white-space:pre-wrap;\">そして注目すべきは、車内の美しいダイニングテーブルやカウンターに採用された、台湾発の高級クォーツブランド <strong>Mikado Quartz 帝雉石</strong> です。</p></div>\n\n\n  \n<style id=\"container-styles\">#block-yui_3_17_2_1_1756882003224_4656 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-yui_3_17_2_1_1756882003224_4656 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initial;\n}\n\n  #block-yui_3_17_2_1_1756882003224_4656 {\n      mix-blend-mode: var(--tweak-text-block-blend\n  );\n      border-radius: var(--tweak-text-block-radius);\n  }\n\n  \n  \n#block-yui_3_17_2_1_1756882003224_4656 {\n      --tweak-text-block-radius: 0px 0px 0px 0px;\n    }\n\n\n  \n  \n\n  #block-yui_3_17_2_1_1756882003224_4656 {\n    }\n\n</style>\n\n<style id=\"override-container-styles\">\n    @media screen and (max-width: 767px) {\n          \n            \n\n#block-yui_3_17_2_1_1756882003224_4656 {\n            \n            }\n        }\n    \n  \n    @media screen and (max-width: 767px) {\n          #block-yui_3_17_2_1_1756882003224_4656 .sqs-html-content {\n            \n            }\n        }\n    \n  @media screen and (max-width: 767px) {\n          \n          \n\n          \n          \n          \n        }</style>\n\n<style class=\"transform-overrides-vars\">\n    \n  </style>\n\n\n\n</div>\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-spacer spacer-block\" data-aspect-ratio=\"1.9298245614035088\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/523604b1-74b7-4792-97e8-b24d3d8ea8c8_1064/website.components.spacer.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/523604b1-74b7-4792-97e8-b24d3d8ea8c8_1064/website.components.spacer.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.spacer\" data-website-component-id=\"yui_3_17_2_1_1756879465658_4064\" id=\"block-yui_3_17_2_1_1756879465658_4064\"><div class=\"sqs-block-content\">&nbsp;</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"yui_3_17_2_1_1756879465658_4692\" id=\"block-yui_3_17_2_1_1756879465658_4692\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"white-space:pre-wrap;\">実用性を兼ね備えた選択</h4><pre><code>列車という特殊な空間では、デザイン性だけでなく耐久性も重要です。\n高密度で丈夫な帝雉石は、揺れる車内でも安心できる安定性を備え、さらに「汚れが付きにくい」「清掃が簡単」という特性から、ダイニングテーブルに最適な素材として選ばれました。\n\n特にダイニングテーブルには厚み2cmのクォーツを使用し、エッジ部分はわずかに立ち上げる工夫を施すことで、走行中の揺れによる料理の滑落を防止。細部まで配慮された設計は、実用性とデザイン性を両立しています。</code></pre></div>\n\n\n  \n<style id=\"container-styles\">#block-yui_3_17_2_1_1756879465658_4692 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-yui_3_17_2_1_1756879465658_4692 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initial;\n}\n\n  #block-yui_3_17_2_1_1756879465658_4692 {\n      mix-blend-mode: var(--tweak-text-block-blend\n  );\n      border-radius: var(--tweak-text-block-radius);\n  }\n\n  \n  \n#block-yui_3_17_2_1_1756879465658_4692 {\n      --tweak-text-block-radius: 0px 0px 0px 0px;\n    }\n\n\n  \n  \n\n  #block-yui_3_17_2_1_1756879465658_4692 {\n    }\n\n</style>\n\n<style id=\"override-container-styles\">\n    @media screen and (max-width: 767px) {\n          \n            \n\n#block-yui_3_17_2_1_1756879465658_4692 {\n            \n            }\n        }\n    \n  \n    @media screen and (max-width: 767px) {\n          #block-yui_3_17_2_1_1756879465658_4692 .sqs-html-content {\n            \n            }\n        }\n    \n  @media screen and (max-width: 767px) {\n          \n          \n\n          \n          \n          \n        }</style>\n\n<style class=\"transform-overrides-vars\">\n    \n  </style>\n\n\n\n</div>\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-spacer spacer-block\" data-aspect-ratio=\"1.9298245614035088\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/523604b1-74b7-4792-97e8-b24d3d8ea8c8_1064/website.components.spacer.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.spacer/523604b1-74b7-4792-97e8-b24d3d8ea8c8_1064/website.components.spacer.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.spacer\" data-website-component-id=\"yui_3_17_2_1_1756882003224_5554\" id=\"block-yui_3_17_2_1_1756882003224_5554\"><div class=\"sqs-block-content\">&nbsp;</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"yui_3_17_2_1_1756882003224_5622\" id=\"block-yui_3_17_2_1_1756882003224_5622\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h4 style=\"white-space:pre-wrap;\">台湾ならではの「移動する美学」</h4><p class=\"\" style=\"white-space:pre-wrap;\">「鳴日廚房」の完成までに約1年半を要し、台湾の素材とデザインを融合させた、他にない鉄道体験が実現しました。<br> Mikado Quartz 帝雉石の上質な素材感は、まさに台湾発の美学を象徴する存在として、この「移動するレストラン」を支えています。</p><p class=\"\" style=\"white-space:pre-wrap;\">エレガントで唯一無二の鉄道旅。<br> それは、台湾のデザイン力と素材力が織りなす新しい物語です。</p></div>\n\n\n  \n<style id=\"container-styles\">#block-yui_3_17_2_1_1756882003224_5622 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-yui_3_17_2_1_1756882003224_5622 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initi