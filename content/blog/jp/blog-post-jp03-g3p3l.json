4000\" alt=\"\" sizes=\"(max-width: 640px) 100vw, (max-width: 767px) 100vw, 100vw\" style=\"display:block;object-fit: cover; width: 100%; height: 100%; object-position: 50% 50%\" onload=\"this.classList.add(&quot;loaded&quot;)\" srcset=\"/images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 100w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 300w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 500w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 750w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 1000w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 1500w, /images/1752483346799-9QNILWX2WE2EM5ELRBG3/DSC00565.jpg 2500w\" loading=\"lazy\" decoding=\"async\" data-loader=\"sqs\">\n\n            </div>\n          </div>\n        \n          \n        \n\n        \n      \n        </figure>\n      \n\n    </div>\n  \n\n\n  \n\n\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-html html-block\" data-block-css=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.styles.css&quot;]\" data-block-scripts=\"[&quot;https://definitions.sqspcdn.com/website-component-definition/static-assets/website.components.html/d92a980d-b660-49d1-a8a9-d817239fa29e_741/website.components.html.visitor.js&quot;]\" data-block-type=\"1337\" data-definition-name=\"website.components.html\" data-sqsp-block=\"text\" data-website-component-id=\"yui_3_17_2_1_1756885416653_21905\" id=\"block-yui_3_17_2_1_1756885416653_21905\"><div class=\"sqs-block-content\"><div class=\"sqs-text-block-container\">\n  \n  <div class=\"sqs-html-content\" data-sqsp-text-block-content><h3 style=\"white-space:pre-wrap;\">幅広い用途 ― キッチン以外にも広がる可能性</h3><p class=\"\" style=\"white-space:pre-wrap;\">帝雉石はキッチンワークトップにとどまらず、さまざまな空間に活用されています：</p><ul data-rte-list=\"default\"><li><p class=\"\" style=\"white-space:pre-wrap;\">住宅空間</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">商業施設</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">アイランドカウンター</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">ダイニングテーブル</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">TVボード</p></li><li><p class=\"\" style=\"white-space:pre-wrap;\">アクセントウォール</p></li></ul><p class=\"\" style=\"white-space:pre-wrap;\">「本当に信頼できるキッチンワークトップを探している」<br> そんな方へ――帝雉石は、デザイン性と機能性を兼ね備えた空間の中心を創り出します。</p><p class=\"\" style=\"white-space:pre-wrap;\">ぜひショールームにて、実際にその質感と仕上がりをご体感ください。</p></div>\n\n\n  \n<style id=\"container-styles\">#block-yui_3_17_2_1_1756885416653_21905 {\n    \n    --stroke-style: none;--stroke-thickness: 6px;\n    \n      \n      \n      \n    \n\n--tweak-text-block-background-color: initial;\n\n  }\n\n  #block-yui_3_17_2_1_1756885416653_21905 .sqs-html-content {\n    \n    --tweak-text-block-padding: 6% 6% 6% 6%;\n  --tweak-text-block-padding: initial;\n}\n\n  #block-yui_3_17_2_1_1756885416653_21905 {\n      mix-blend-mode: var(--tweak-text-block-blend\n  );\n      border-radius: var(--tweak-text-block-radius);\n  }\n\n  \n  \n#block-yui_3_17_2_1_1756885416653_21905 {\n      --tweak-text-block-radius: 0px 0px 0px 0px;\n    }\n\n\n  \n  \n\n  #block-yui_3_17_2_1_1756885416653_21905 {\n    }\n\n</style>\n\n<style id=\"override-container-styles\">\n    @media screen and (max-width: 767px) {\n          \n            \n\n#block-yui_3_17_2_1_1756885416653_21905 {\n            \n            }\n        }\n    \n  \n    @media screen and (max-width: 767px) {\n          #block-yui_3_17_2_1_1756885416653_21905 .sqs-html-content {\n            \n            }\n        }\n    \n  @media screen and (max-width: 767px) {\n          \n          \n\n          \n          \n          \n        }</style>\n\n<style class=\"transform-overrides-vars\">\n    \n  </style>\n\n\n\n</div>\n</div></div><div class=\"sqs-block website-component-block sqs-block-website-component sqs-block-spacer spacer-block sized vs